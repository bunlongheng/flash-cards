# Example .env file - copy to .env and fill in.

# Comma-separated category slugs. Each must have a matching src/data/<slug>.json.
REACT_APP_CATEGORIES=shapes,planets,animals

# Comma-separated slugs for the random transportation banner on the home screen.
REACT_APP_TRANSPORTATION_TYPES=airplane,train,boat

# Optional: greeting shown on the home screen (defaults to "Hi!").
REACT_APP_GREETING=Hi!

# Optional: set to true to enable the webpack bundle analyzer.
ANALYZE=false
