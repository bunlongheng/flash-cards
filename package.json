	"scripts": {
		"start": "react-scripts start",
		"build": "react-scripts build",
		"test": "react-scripts test",
		"eject": "react-scripts eject",
		"analyze": "webpack --profile --json > stats.json",
		"analyze:full": "webpack --config analyze/webpack.full.js && npx webpack-bundle-analyzer analyze/stats-full.json",
		"analyze:src": "webpack --config analyze/webpack.src-only.js && npx webpack-bundle-analyzer analyze/stats-src.json"
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"react-app/jest"
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"devDependencies": {
		"madge": "^8.0.0",
		"nodemon": "^2.0.22",
		"webpack": "^5.98.0",
		"webpack-bundle-analyzer": "^4.10.2",
		"webpack-cli": "^6.0.1"
